# =============================================================================
# Hugh Assistant — Environment Variables
# =============================================================================
# Copy to .env.local and fill in real values:  cp .env.example .env.local

# --- Auth ---
# Generate with: openssl rand -base64 48
AUTH_SECRET=
# Google OAuth credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Single email address allowed to sign in
ALLOWED_EMAIL=

# --- AI ---
# Anthropic API key (starts with sk-ant-)
ANTHROPIC_API_KEY=

# --- Database ---
# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@postgres:5432/hugh_assistant

# --- MCP Google Workspace (optional — chat works without these) ---
# Two MCP approaches are supported:
#   1. SDK client (SSE): Proxies through Next.js server. Works with private MCP servers.
#   2. Provider options: Anthropic calls MCP server directly. Requires public URL.
# Both use the same env vars below. See docs/MCP_DEPLOYMENT.md for setup guide.
#
# URL of the Google Workspace MCP server (SSE endpoint)
# MCP_GOOGLE_WORKSPACE_URL=http://mcp-backend:8080/mcp
# Bearer token for MCP server authentication
# MCP_AUTH_TOKEN=
